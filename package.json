{
    "name": "frontend-foundation",
    "version": "0.0.1",
    "type": "module",
    "private": true,
    "scripts": {
        "dev": "next dev",
        "build": "next build",
        "start": "next start",
        "lint": "eslint",
        "format": "prettier --write \"**/*.{ts,tsx}\"",
        "typecheck": "tsc --noEmit",
        "storybook": "storybook dev -p 6006",
        "build-storybook": "storybook build",
        "icons:clean": "rimraf src/components/Icons",
        "icons:generate": "npm run icons:clean && svgr --no-prettier --icon --typescript --filename-case kebab --jsx-runtime automatic --svg-props width=20,height=20 --replace-attr-values \"#000=currentColor,#fff=currentColor\" --out-dir src/components/_icons public/icons",
        "test": "vitest --project unit",
        "test:watch": "vitest --project unit --watch",
        "test:coverage": "vitest --project unit --coverage"
    },
    "dependencies": {
        "@base-ui/react": "^1.5.0",
        "@hookform/resolvers": "^5.4.0",
        "@tanstack/react-table": "^8.21.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "date-fns": "^4.4.0",
        "input-otp": "^1.4.2",
        "lucide-react": "^1.17.0",
        "motion": "^12.40.0",
        "next": "16.2.6",
        "next-themes": "^0.4.6",
        "radix-ui": "^1.4.3",
        "react": "19.2.4",
        "react-day-picker": "^10.0.1",
        "react-dom": "19.2.4",
        "react-hook-form": "^7.79.0",
        "react-scan": "^0.5.7",
        "shadcn": "^4.10.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.6.0",
        "tw-animate-css": "^1.4.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@chromatic-com/storybook": "^5.2.1",
        "@storybook/addon-a11y": "^10.4.2",
        "@storybook/addon-docs": "^10.4.2",
        "@storybook/addon-themes": "^10.4.4",
        "@storybook/addon-vitest": "^10.4.2",
        "@storybook/nextjs-vite": "^10.4.2",
        "@svgr/cli": "^8.1.0",
        "@tailwindcss/postcss": "^4",
        "@testing-library/dom": "^10.4.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "@vitejs/plugin-react": "^6.0.2",
        "@vitest/browser-playwright": "^4.1.8",
        "@vitest/coverage-v8": "^4.1.8",
        "eslint": "^9",
        "eslint-config-next": "16.2.6",
        "eslint-plugin-storybook": "^10.4.2",
        "happy-dom": "^20.10.5",
        "playwright": "^1.60.0",
        "prettier": "^3.8.3",
        "prettier-plugin-tailwindcss": "^0.8.0",
        "rimraf": "^6.1.3",
        "storybook": "^10.4.2",
        "storybook-addon-grid": "^0.7.1",
        "storybook-addon-pseudo-states": "^10.4.4",
        "storybook-dark-mode": "^5.0.0",
        "tailwindcss": "^4",
        "typescript": "^5",
        "vite": "^8.0.16",
        "vitest": "^4.1.8"
    }
}
